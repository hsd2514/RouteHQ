# Use 127.0.0.1, not "localhost" -- on Windows, "localhost" often resolves to
# IPv6 (::1) first and times out for ~20s before falling back to IPv4.
# Port 5433 assumes a Postgres container mapped off the default 5432
# (useful if a native Postgres service is already using 5432 on your machine).
# If you don't have that conflict, 5432 works fine too.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/transitops
JWT_SECRET=dev-secret-change-me-in-production
